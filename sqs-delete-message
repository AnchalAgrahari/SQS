# to receive message
response = client.receive_message(
    QueueUrl = 'https://sqs.us-west-2.amazonaws.com/697429983773/signup-data-queue'   
)
# we also need receipt handle to delete msg
# It is a temporary permission token given by AWS(receipthandle)
# to get receipt handle
message = response['Messages'][0]
receipt_handle=message['ReceiptHandle']


client.delete_message(
    QueueUrl='https://sqs.us-west-2.amazonaws.com/697429983773/signup-data-queue',
    ReceiptHandle=receipt_handle
    )

