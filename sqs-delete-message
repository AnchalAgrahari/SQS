import boto3

client = boto3.client('sqs')

def receive_message(queueurl):
    try:
        response=client.receive_message(
            QueueUrl=queueurl
        )
        print(response)

        if 'Message' in response:
            message=response['Message'][0]
            receipt_handle=message['ReceiptHandle']


            client.delete_message(
                QueueUrl=queueurl,
                ReceiptHandle=receipt_handle
            )
            print("Message Deleted Successfully")

    except client.exceptions.ReceiptHandleIsInvalid as e:
        print("Invalit Receipt Handle",e)

    except client.exceptions.QueueDoesNotExist as e:
        print("Queue dose not Exit",e)
    except Exception as e:
        print("No message Found",e)



if __name__=='__main__':
    try:
        queueurl=input("Enter the URL of the Queue: ").strip()
        print ("Message Deleted Successfully")        
    except Exception as e:
        print("An Unknown error has Occurred",e)